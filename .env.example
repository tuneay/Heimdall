# ════════════════════════════════════════════════════════════════════
#  Heimdall — environment template
#  Copy to `.env` and fill in. NEVER commit `.env`.
# ════════════════════════════════════════════════════════════════════

# ─── Core database (Postgres + TimescaleDB + pgvector) ───────────────
POSTGRES_USER=heimdall
POSTGRES_PASSWORD=change-me-in-dev
POSTGRES_DB=heimdall
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
# SQLAlchemy / async URL derived from the above:
DATABASE_URL=postgresql+psycopg://heimdall:change-me-in-dev@localhost:5432/heimdall

# ─── Cache / queue ───────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ─── Object storage (MinIO, S3-compatible) ───────────────────────────
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=heimdall
S3_SECRET_KEY=change-me-in-dev
S3_BUCKET=heimdall-lake

# ─── MLflow (experiment tracking + model registry) ───────────────────
MLFLOW_TRACKING_URI=http://localhost:5000

# ─── Observability (OpenTelemetry) ───────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=heimdall-api
OTEL_TRACES_SAMPLER=parentbased_always_on

# ─── Web app → API ───────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# ─── Data source credentials (fill as phases come online) ────────────
# TCMB EVDS macro API key — https://evds2.tcmb.gov.tr (Faz 3)
TCMB_EVDS_API_KEY=
# Anthropic — used for Turkish NLP event/entity extraction (Faz 4–5)
ANTHROPIC_API_KEY=
# Broker / real-time BIST feed (Faz 14+ / 18) — leave blank until needed
ALGOLAB_API_KEY=
ALGOLAB_USERNAME=
ALGOLAB_PASSWORD=
